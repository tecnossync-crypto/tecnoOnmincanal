# =============================================================================
# .env.example — Variables de entorno para producción
# Copia este archivo como /opt/tecnossync/.env.prod en el servidor
# y rellena TODOS los valores antes del primer deploy.
# =============================================================================

# ─── NODE ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ─── BASE DE DATOS (RDS PostgreSQL) ──────────────────────────────────────────
# Obtener con: aws rds describe-db-instances --db-instance-identifier tecnossync-db ...
DB_HOST=tecnossync-db.xxxxxxxxxxxx.us-east-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=tecnossync
DB_USER=tecnossync_admin
DB_PASSWORD=CAMBIA_ESTO_PASSWORD_SEGURA
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000
DB_SSL=true

# ─── REDIS (ElastiCache) ─────────────────────────────────────────────────────
# Obtener con: aws elasticache describe-cache-clusters --cache-cluster-id tecnossync-redis ...
REDIS_HOST=tecnossync-redis.xxxxxxxxxxxx.0001.use1.cache.amazonaws.com
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=GENERA_CON_openssl_rand_-base64_64
JWT_EXPIRES_IN=7d

# ─── DOMINIO / CORS ──────────────────────────────────────────────────────────
FRONTEND_URL=https://tudominio.com
CORS_ORIGINS=https://tudominio.com

# ─── META / WHATSAPP BUSINESS ────────────────────────────────────────────────
META_APP_ID=TU_META_APP_ID
META_APP_SECRET=TU_META_APP_SECRET
META_WEBHOOK_VERIFY_TOKEN=TOKEN_SECRETO_WEBHOOK
META_API_VERSION=v18.0

# ─── AI PROVIDERS ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-XXXX
OPENAI_API_KEY=sk-XXXX
GEMINI_API_KEY=AIzaSy_XXXX

# ─── SESIONES BAILEYS (WhatsApp personal) ────────────────────────────────────
SESSIONS_PATH=/app/sessions

# ─── UPLOADS ─────────────────────────────────────────────────────────────────
UPLOAD_PATH=/app/uploads
UPLOAD_MAX_SIZE=52428800

# ─── OUTLOOK CALENDAR (Microsoft Graph) ─────────────────────────────────────
OUTLOOK_CLIENT_ID=TU_OUTLOOK_CLIENT_ID
OUTLOOK_CLIENT_SECRET=TU_OUTLOOK_CLIENT_SECRET
OUTLOOK_REDIRECT_URI=https://tudominio.com/api/outlook/callback

# ─── GOOGLE CALENDAR ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=TU_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=TU_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=https://tudominio.com/api/gcal/callback

# ─── ZOHO MAIL (recuperación de contraseña) ─────────────────────────────────
# Puerto 465 (SSL) recomendado para Zoho
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=notificaciones@tudominio.com   # tu correo Zoho
SMTP_PASS=TU_PASSWORD_ZOHO               # contraseña de la cuenta Zoho
SMTP_FROM=notificaciones@tudominio.com   # puede ser igual a SMTP_USER

# ─── CI/CD (para el panel SuperAdmin) ───────────────────────────────────────
# Token de GitHub con permiso: actions:write, repo
GITHUB_TOKEN=ghp_XXXX
GITHUB_OWNER=tecnossync-crypto
GITHUB_REPO=omnichannel

# ─── LOGS ────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_PATH=/app/logs

# ─── RATE LIMITING ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=500
